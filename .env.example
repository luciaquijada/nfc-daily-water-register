# --- Frontend (Vite) ---
# PUBLIC variables: embedded in the browser bundle. Never put secrets
# behind the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_APP_URL=http://localhost:5173

# --- Supabase Edge Functions (server) ---
