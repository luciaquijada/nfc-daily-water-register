# --- Frontend (Vite) ---
# Variables PÚBLICAS: se incrustan en el bundle del navegador. Nunca pongas
# secretos con el prefijo VITE_. Aún sin usar en la Fase 1.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_APP_URL=http://localhost:5173

# --- Supabase Edge Functions (servidor) ---
# Variables PRIVADAS. NO van en este archivo del frontend ni llevan prefijo VITE_.
# Se configuran como secretos en el panel de Supabase (Fase 8):
#   OPENAI_API_KEY=
#   OPENAI_MODEL=
